carbonpulse:
  target: dev
  outputs:
    dev:
      type: duckdb
      path: /tmp/carbonpulse_dev.duckdb
      threads: 4
    prod:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      database: CARBONPULSE
      warehouse: CARBONPULSE_WH
      schema: MARTS
      role: SYSADMIN
